+@pytest.fixture
+def test_db():
+    """Create temporary test database for each test"""
+    Base.metadata.create_all(bind=test_engine)
+    yield SessionLocal(bind=test_engine)
+    Base.metadata.drop_all(bind=test_engine)
+
+def test_list_sites(test_db):
