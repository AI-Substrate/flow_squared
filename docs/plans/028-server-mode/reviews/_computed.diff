+-- Indexes: api_keys
+CREATE INDEX IF NOT EXISTS idx_api_keys_hash ON api_keys(key_hash)
+    WHERE is_active = true;
+CREATE INDEX IF NOT EXISTS idx_api_keys_tenant ON api_keys(tenant_id);
 """
 
 
