+  "category": "type",
+  "ts_kind": "class_definition",
+  "name": "AuthService",
+  "qualified_name": "AuthService",
+  "start_line": 15,
+  "end_line": 89,
+  "content": "class AuthService:\n    ...",
+  "smart_content": "AuthService handles JWT-based auth...",
+  "language": "python",
+  "graph_name": "api-gateway"
+}
+```
