+{% extends "base.html" %}
+
+{% block title %}Upload Graph — fs2 Server{% endblock %}
+
+{% block content %}
+<h1>Upload Graph</h1>
+
+<p>Upload a graph pickle file generated by <code>fs2 scan --embed</code>.</p>
+
+{% if error %}
+<div class="flash flash-error">
+    <strong>Upload failed:</strong> {{ error }}
+</div>
+{% endif %}
+
+{% if success %}
+<div class="flash flash-success">
+    <strong>Graph uploaded successfully!</strong>
+    {{ success.name }} — {{ success.node_count }} nodes, {{ success.edge_count }} edges.
+    <br><a href="/dashboard/graphs">← Back to graphs</a>
+</div>
+{% endif %}
+
+<article>
+    <form id="upload-form" method="post" enctype="multipart/form-data"
+          action="/dashboard/graphs/upload">
+
+        <label for="name">Graph Name *</label>
+        <input type="text" id="name" name="name" required
+               placeholder="e.g. my-repo, hve-core">
+
+        <label for="description">Description</label>
+        <input type="text" id="description" name="description"
+               placeholder="Optional description">
+
+        <label for="source_url">Source URL</label>
+        <input type="url" id="source_url" name="source_url"
+               placeholder="e.g. https://github.com/org/repo">
+
+        <label for="file">Graph Pickle File *</label>
+        <input type="file" id="file" name="file" required accept=".pickle,.pkl">
+
+        <div class="progress-bar" id="progress-container">
+            <div class="progress-bar-fill" id="progress-fill" style="width: 0%"></div>
+        </div>
+        <p id="progress-text" style="display: none;" class="text-muted"></p>
+
+        <button type="submit" id="upload-btn">Upload & Ingest</button>
+    </form>
+</article>
+{% endblock %}
+
+{% block extra_scripts %}
+<script>
+// Vanilla JS upload progress (DYK-P6-07)
+document.getElementById('upload-form').addEventListener('submit', function(e) {
+    e.preventDefault();
+
+    const form = e.target;
+    const formData = new FormData(form);
+    const btn = document.getElementById('upload-btn');
+    const progressContainer = document.getElementById('progress-container');
+    const progressFill = document.getElementById('progress-fill');
+    const progressText = document.getElementById('progress-text');
+
+    btn.disabled = true;
+    btn.setAttribute('aria-busy', 'true');
+    btn.textContent = 'Uploading…';
+    progressContainer.style.display = 'block';
+    progressText.style.display = 'block';
+
+    const xhr = new XMLHttpRequest();
+
+    xhr.upload.addEventListener('progress', function(e) {
+        if (e.lengthComputable) {
+            const pct = Math.round((e.loaded / e.total) * 100);
+            progressFill.style.width = pct + '%';
+            const mb = (e.loaded / 1048576).toFixed(1);
+            const totalMb = (e.total / 1048576).toFixed(1);
+            progressText.textContent = pct + '% (' + mb + ' / ' + totalMb + ' MB)';
+            if (pct >= 100) {
+                btn.textContent = 'Ingesting…';
+                progressText.textContent = 'Upload complete. Ingesting graph…';
+            }
+        }
+    });
+
+    xhr.addEventListener('load', function() {
+        // Server returns HTML — replace the page content
+        document.open();
+        document.write(xhr.responseText);
+        document.close();
+    });
+
+    xhr.addEventListener('error', function() {
+        btn.disabled = false;
+        btn.setAttribute('aria-busy', 'false');
+        btn.textContent = 'Upload & Ingest';
+        progressText.textContent = 'Upload failed. Please try again.';
+        progressText.style.color = 'var(--fs2-red)';
+    });
+
+    xhr.open('POST', form.action);
+    xhr.send(formData);
+});
+</script>
+{% endblock %}
