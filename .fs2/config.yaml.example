# .fs2/config.yaml.example
#
# Flowspace2 Configuration Example
#
# Copy this file to .fs2/config.yaml and customize for your environment:
#   cp .fs2/config.yaml.example .fs2/config.yaml
#
# IMPORTANT: Never commit .fs2/config.yaml - it may contain secrets via placeholders.
# The actual secrets should be in environment variables, secrets.env, or .env (gitignored).
#
# ============================================================================
# CONFIGURATION ARCHITECTURE
# ============================================================================
#
# Flowspace2 uses a typed-object ConfigurationService pattern:
#
#   from fs2.config import FS2ConfigurationService, AzureOpenAIConfig
#   config = FS2ConfigurationService()  # Loads this YAML + env vars
#   azure = config.get(AzureOpenAIConfig)  # Get typed config object
#
# Config Types:
#   - AzureOpenAIConfig: Azure OpenAI settings (__config_path__ = "azure.openai")
#   - SearchQueryConfig: CLI query settings (__config_path__ = None, CLI-only)
#
# ============================================================================
# PRECEDENCE (lowest to highest)
# ============================================================================
#
# 1. Config object defaults (in code)
# 2. User YAML (~/.config/fs2/config.yaml)
# 3. Project YAML (./.fs2/config.yaml) - this file
# 4. Environment vars (FS2_* prefix)
#
# Secrets precedence (loaded into os.environ):
# 1. OS environment (base layer)
# 2. User secrets (~/.config/fs2/secrets.env)
# 3. Project secrets (./.fs2/secrets.env)
# 4. Working dir .env (./.env wins over everything)
#
# ============================================================================
# ENVIRONMENT VARIABLE CONVENTION
# ============================================================================
#
# No manual mapping required - pure convention:
#   FS2_AZURE__OPENAI__TIMEOUT=120
#       ^^^^^^^^^^^^^^^^^^^^^^
#       Lowercased, __ becomes . → azure.openai.timeout
#
# Examples:
#   FS2_AZURE__OPENAI__ENDPOINT=https://example.com → azure.openai.endpoint
#   FS2_AZURE__OPENAI__TIMEOUT=60 → azure.openai.timeout
#
# ============================================================================

azure:
  openai:
    # Azure OpenAI endpoint URL
    # Set via: FS2_AZURE__OPENAI__ENDPOINT
    endpoint: null  # e.g., https://your-resource.openai.azure.com

    # API version for Azure OpenAI
    api_version: "2024-02-01"

    # Deployment name in your Azure OpenAI resource
    # Set via: FS2_AZURE__OPENAI__DEPLOYMENT_NAME
    deployment_name: null  # e.g., gpt-4-turbo

    # API key - use ${VAR} placeholder, NOT literal secret!
    # Option 1: Placeholder (loaded from secrets.env or .env)
    #   api_key: ${AZURE_OPENAI_API_KEY}
    # Option 2: Direct env var
    #   FS2_AZURE__OPENAI__API_KEY=your-key
    #
    # Security: Literal secrets (sk-*, 64+ char strings) are rejected.
    api_key: null

    # Request timeout in seconds (1-300)
    # Set via: FS2_AZURE__OPENAI__TIMEOUT
    timeout: 30

# ============================================================================
# SECRETS FILE EXAMPLE
# ============================================================================
#
# Create .fs2/secrets.env (gitignored):
#   AZURE_OPENAI_API_KEY=your-actual-api-key
#
# Then reference in YAML:
#   api_key: ${AZURE_OPENAI_API_KEY}
#
# Or use .env file in project root for all secrets.
