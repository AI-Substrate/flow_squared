# .fs2/secrets.env.example
#
# Project-level secrets for Flowspace2
#
# Copy this file to .fs2/secrets.env:
#   cp .fs2/secrets.env.example .fs2/secrets.env
#
# IMPORTANT: Never commit secrets.env - it contains actual secrets!
# This file is loaded via python-dotenv into os.environ.
#
# ============================================================================
# SECRETS LOADING ORDER
# ============================================================================
#
# Secrets are loaded into os.environ in this order (highest priority last):
# 1. OS environment variables (base layer)
# 2. ~/.config/fs2/secrets.env (user-level)
# 3. ./.fs2/secrets.env (this file - project-level)
# 4. ./.env (wins over everything - standard dotenv behavior)
#
# ============================================================================
# USAGE IN CONFIG
# ============================================================================
#
# After loading, reference in .fs2/config.yaml via ${VAR}:
#   azure:
#     openai:
#       api_key: ${AZURE_OPENAI_API_KEY}
#
# Or override directly via FS2_* env vars:
#   FS2_AZURE__OPENAI__API_KEY=your-key
#
# ============================================================================

# Azure OpenAI API Key
# AZURE_OPENAI_API_KEY=your-azure-openai-api-key

# Other secrets can be added here:
# DATABASE_PASSWORD=your-db-password
# EXTERNAL_API_KEY=your-api-key
