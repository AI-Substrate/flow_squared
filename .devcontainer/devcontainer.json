// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/python
{
	"name": "Python 3",
	// Use docker-compose for explicit port binding (0.0.0.0 for remote access)
	"dockerComposeFile": "compose.yml",
	"service": "devcontainer",
	"workspaceFolder": "/workspaces/flow_squared",

	"features": {
		"ghcr.io/ai-substrate/devcontainer-features/flowspace:latest": {
      		"version": "latest"
    	},
		"ghcr.io/devcontainers/features/docker-outside-of-docker:1": {},
		"ghcr.io/devcontainers/features/rust:1": {},
		"ghcr.io/devcontainers/features/common-utils:2": {
			"installZsh": true,
			"configureZshAsDefaultShell": true,
			"installOhMyZsh": true,
			"installOhMyZshConfig": true,
			"upgradePackages": true,
			"nonFreePackages": true,
			"username": "vscode",
			"userUid": "automatic",
			"userGid": "automatic"
		}
	},

	// Run post-install script after the container is created
	"postCreateCommand": "/usr/local/share/ssh-init.sh && /usr/local/bin/post-install.sh && grep -q 'alias fs2=' ~/.zshrc || echo 'alias fs2=\"uv run fs2\"' >> ~/.zshrc",
	"postStartCommand": "/usr/local/share/ssh-init.sh",

	// Mounts are in compose.yml, ports exposed via 0.0.0.0:2225 for remote SSH access
	"remoteEnv": {
        "HOST_PROJECT_PATH": "${localWorkspaceFolder}", // The shim looks for this when running in a container
        
        
        "SSH_AUTH_SOCK": "/ssh-agent"
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"bierner.github-markdown-preview",
				"bierner.markdown-mermaid"
			]
		}
	}
	// Features to add to the dev container. More info: https://containers.dev/features.
	// "features": {},

	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	// "forwardPorts": [],

	// Configure tool-specific properties.
	// "customizations": {},

	// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
	// "remoteUser": "root"
}
