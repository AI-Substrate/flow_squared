# fs2 Secrets Environment File Example
# Copy this file to one of these locations:
#   - ~/.config/fs2/secrets.env  (user-level, shared across projects)
#   - .fs2/secrets.env           (project-specific)
#   - .env                       (working directory, highest priority)
#
# IMPORTANT: Add secrets.env and .env to .gitignore to avoid committing secrets!
#
# Precedence (lowest to highest):
#   1. ~/.config/fs2/secrets.env
#   2. .fs2/secrets.env
#   3. .env

# =============================================================================
# AZURE OPENAI CONFIGURATION
# =============================================================================
# For Azure OpenAI LLM and embedding services.
# Get these values from Azure Portal > Azure OpenAI > Keys and Endpoint

# LLM (Chat/Completion) API Key
AZURE_OPENAI_API_KEY=your-azure-openai-api-key-here

# LLM Endpoint URL
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# Embedding API Key (may be same as LLM key if using same resource)
AZURE_EMBEDDING_API_KEY=your-azure-embedding-api-key-here

# Embedding Endpoint URL
AZURE_EMBEDDING_ENDPOINT=https://your-resource.openai.azure.com

# =============================================================================
# OPENAI CONFIGURATION
# =============================================================================
# For OpenAI API (not Azure).
# Get your API key from https://platform.openai.com/api-keys

# OPENAI_API_KEY=sk-your-openai-api-key-here

# =============================================================================
# CUSTOM ENVIRONMENT VARIABLES
# =============================================================================
# Add any custom variables needed by your project.
# Reference them in config.yaml using ${VAR_NAME} syntax.

# MY_CUSTOM_API_KEY=your-custom-key-here
