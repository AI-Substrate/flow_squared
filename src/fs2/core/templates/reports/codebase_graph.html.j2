<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>fs2 — Codebase Graph</title>
    <style>
        /* Embedded fonts */
        @font-face {
            font-family: 'Inter';
            font-style: normal;
            font-weight: 400 600;
            font-display: swap;
            src: url(data:font/woff2;base64,{{ inter_font_b64 }}) format('woff2');
            unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
        }
        @font-face {
            font-family: 'JetBrains Mono';
            font-style: normal;
            font-weight: 400 500;
            font-display: swap;
            src: url(data:font/woff2;base64,{{ jetbrains_mono_font_b64 }}) format('woff2');
            unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
        }

        /* Cosmos dark theme */
        {{ graph_viewer_css }}
    </style>
</head>
<body>
    <!-- Loading Screen -->
    <div id="loading-screen">
        <div class="loading-title">fs2 — <span class="accent name"></span></div>
        <div class="loading-subtitle"></div>
        <div class="loading-stats">
            <div class="loading-stat">
                <div class="value">0</div>
                <div class="label">Nodes</div>
            </div>
            <div class="loading-stat">
                <div class="value">0</div>
                <div class="label">References</div>
            </div>
            <div class="loading-stat">
                <div class="value">0</div>
                <div class="label">Containment</div>
            </div>
        </div>
        <div class="loading-spinner"></div>
    </div>

    <!-- Sigma.js Canvas -->
    <div id="sigma-container"></div>

    <!-- Project Title -->
    <div class="project-title">
        fs2 — <span class="name"></span>
    </div>

    <!-- Category Legend -->
    <div class="category-legend" id="category-legend"></div>

    <!-- Status Bar -->
    <div class="status-bar">
        <span class="status-item"><span class="status-value" id="status-nodes"></span></span>
        <span class="status-separator"></span>
        <span class="status-item"><span class="status-value" id="status-refs"></span></span>
        <span class="status-version" id="status-version"></span>
    </div>

    <!-- Embedded graph data -->
    <script>
        var GRAPH_DATA = {{ graph_json }};
        var METADATA = {{ metadata_json }};
    </script>

    <!-- Vendored libraries -->
    <script>{{ graphology_js }}</script>
    <script>{{ sigma_js }}</script>

    <!-- Graph viewer -->
    <script>{{ graph_viewer_js }}</script>
</body>
</html>
