{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Code Review Report",
  "type": "object",
  "required": [
    "verdict",
    "findings",
    "domainCompliance",
    "coverageMap",
    "summary",
    "retrospective"
  ],
  "additionalProperties": true,
  "properties": {
    "verdict": {
      "type": "string",
      "enum": ["APPROVE", "APPROVE_WITH_NOTES", "REQUEST_CHANGES"],
      "description": "Review verdict"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "severity", "file", "category", "issue", "recommendation"],
        "properties": {
          "id": { "type": "string" },
          "severity": { "type": "string", "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW"] },
          "file": { "type": "string" },
          "line": { "type": "integer" },
          "category": { "type": "string" },
          "issue": { "type": "string" },
          "recommendation": { "type": "string" }
        }
      }
    },
    "domainCompliance": {
      "type": "object",
      "properties": {
        "filePlacement": { "type": "string" },
        "dependencyDirection": { "type": "string" },
        "abcContracts": { "type": "string" },
        "fakesOverMocks": { "type": "string" }
      }
    },
    "coverageMap": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "ac": { "type": "string" },
          "confidence": { "type": "number" },
          "evidence": { "type": "string" }
        }
      }
    },
    "summary": {
      "type": "string",
      "minLength": 20
    },
    "retrospective": {
      "type": "object",
      "required": ["workedWell", "confusing", "magicWand"],
      "additionalProperties": true,
      "properties": {
        "workedWell": { "type": "string", "minLength": 10 },
        "confusing": { "type": "string", "minLength": 10 },
        "magicWand": { "type": "string", "minLength": 20 },
        "magicWandTarget": {
          "type": "string",
          "enum": ["project", "minih"],
          "description": "Which system does the magic wand target?"
        },
        "difficulties": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["category", "description", "severity"],
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string", "description": "Self-assigned ID (e.g., MH-001)." },
              "category": { "type": "string", "minLength": 2 },
              "description": { "type": "string", "minLength": 10 },
              "workaround": { "type": ["string", "null"] },
              "severity": { "type": "string", "enum": ["blocking", "degrading", "annoying"] }
            }
          }
        }
      }
    }
  }
}